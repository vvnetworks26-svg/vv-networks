{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "db:seed": "tsx src/database/seed.ts",
    "env:check": "tsx -e \"import('./src/server/env-validator.js').then(m => m.assertEnvironment())\""
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/compression": "^1.7.5",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "2.4.3",
    "compression": "^1.7.5",
    "cors": "2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "7.5.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "lucide-react": "^0.546.0",
    "mongoose": "8.15.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "stripe": "^17.7.0",
    "vite": "^6.2.3",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "9.0.9",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
