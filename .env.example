# ══════════════════════════════════════════════════════════════════════════════
# VV Networks — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# See docs/ENVIRONMENT.md for full documentation.
# ══════════════════════════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"           # development | staging | production
PORT=3000
APP_NAME="vv-networks"
APP_VERSION="0.0.0"
APP_URL="http://localhost:3000"  # production: https://vv-networks.onrender.com
GIT_COMMIT="local"               # injected by CI in production

# ── Database ──────────────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=""

# ── Authentication ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-before-deploying-to-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"
BCRYPT_ROUNDS="12"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development: * (allow all)
# Production:  https://your-app.vercel.app (comma-separated for multiple)
CORS_ORIGIN="*"

# ── Stripe (Phase I.6) ────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""             # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=""         # whsec_... from Stripe CLI or dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""  # pk_live_... or pk_test_...

# ── AI ────────────────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# Leave EMPTY in both development and production.
# Development: Vite proxy (vite.config.ts server.proxy) forwards /api/* to Express.
# Production:  vercel.json rewrites /api/(.*) → Render backend server-side.
#              The browser never sees the Render URL — no CORS issues.
#
# Only set this if bypassing the Vercel proxy (e.g. direct Render testing):
# VITE_API_URL="https://vv-networks-api.onrender.com"
VITE_API_URL=""

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="debug"                # debug | info | warn | error | fatal
LOG_FORMAT="pretty"              # pretty (dev) | json (production)

# ── Security ──────────────────────────────────────────────────────────────────
TRUST_PROXY="false"              # true in production (behind Render/Vercel)
COMPRESSION_ENABLED="false"      # true in production

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="100"

# ── Monitoring ────────────────────────────────────────────────────────────────
METRICS_ENABLED="true"
