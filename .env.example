# ── Backend (Render / local dev) ──────────────────────────────────────────────

# Port the Express server listens on
PORT=3000

# Google Gemini API key — required for LeadFlow AI chat
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Allowed CORS origin(s) for the API
# Development: * (allow all)
# Production:  https://your-vercel-domain.vercel.app
CORS_ORIGIN="*"

# Node environment
NODE_ENV="development"

# ── Frontend (Vercel) ──────────────────────────────────────────────────────────

# Base URL of the deployed backend API (Render service URL)
# Leave empty in development — Vite proxy handles /api/* automatically
# Example: https://vv-networks-api.onrender.com
VITE_API_URL=""
